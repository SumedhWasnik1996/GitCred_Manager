<Window x:Class="GitCredMan.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:GitCredMan.App.Views"
        xmlns:conv="clr-namespace:GitCredMan.App.Converters"
        x:Name="RootWindow"
        Title="Git Credential Manager"
        Width="680" Height="440"
        MinWidth="680" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}"
        Icon="/Resources/Icons/app.ico">

  <Window.Resources>
    <conv:BoolToVisibility        x:Key="BoolToVis"/>
    <conv:InverseBoolToVisibility x:Key="InvBoolToVis"/>
    <conv:NullToVisibility        x:Key="NullToVis"/>
    <conv:ThemeToDisplayName      x:Key="ThemeName"/>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="58"/>   <!-- nav rail -->
      <ColumnDefinition Width="1"/>    <!-- divider -->
      <ColumnDefinition Width="*"/>    <!-- content -->
    </Grid.ColumnDefinitions>

    <!-- ══ VERTICAL NAV RAIL ══════════════════════════════════ -->
    <Border Grid.Column="0"
            Background="{DynamicResource PanelBg}"
            BorderBrush="{DynamicResource SeparatorBrush}"
            BorderThickness="0,0,1,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="52"/>   <!-- logo -->
          <RowDefinition Height="Auto"/> <!-- separator -->
          <RowDefinition Height="*"/>    <!-- nav items -->
          <RowDefinition Height="Auto"/> <!-- bottom actions -->
        </Grid.RowDefinitions>

        <!-- Logo image -->
        <Border Grid.Row="0" ToolTip="Git Credential Manager"
                Background="Transparent">
          <Image Source="/Resources/Icons/logo_32.png"
                 Width="26" Height="26"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <Separator Grid.Row="1" Margin="8,0"/>

        <!-- Nav items -->
        <StackPanel Grid.Row="2" Margin="0,6,0,0">

          <!-- ACCOUNTS -->
          <Grid Height="52" Margin="0,1">
            <Border Width="3" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                    CornerRadius="0,3,3,0" Background="{DynamicResource AccentBrush}">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.ActivePage, ElementName=RootWindow}" Value="0">
                      <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
            </Border>
            <Button Click="NavAccounts_Click" Background="Transparent" BorderThickness="0"
                    Width="58" Height="52" Cursor="Hand" FocusVisualStyle="{x:Null}"
                    ToolTip="Accounts">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="Bg" Background="Transparent">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                      <TextBlock Text="🔑" FontSize="16" HorizontalAlignment="Center"/>
                      <TextBlock Text="Accounts" FontSize="8" HorizontalAlignment="Center" Margin="0,2,0,0">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding DataContext.ActivePage, ElementName=RootWindow}" Value="0">
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </StackPanel>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBg}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SelectedBg}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </Grid>

          <!-- REPOSITORIES -->
          <Grid Height="52" Margin="0,1">
            <Border Width="3" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                    CornerRadius="0,3,3,0" Background="{DynamicResource AccentBrush}">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.ActivePage, ElementName=RootWindow}" Value="1">
                      <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
            </Border>
            <Button Click="NavRepos_Click" Background="Transparent" BorderThickness="0"
                    Width="58" Height="52" Cursor="Hand" FocusVisualStyle="{x:Null}"
                    ToolTip="Repositories">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="Bg" Background="Transparent">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                      <TextBlock Text="📂" FontSize="16" HorizontalAlignment="Center"/>
                      <TextBlock Text="Repos" FontSize="8" HorizontalAlignment="Center" Margin="0,2,0,0">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding DataContext.ActivePage, ElementName=RootWindow}" Value="1">
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </StackPanel>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBg}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SelectedBg}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </Grid>

        </StackPanel>

        <!-- Bottom: Apply + Theme -->
        <StackPanel Grid.Row="3" Margin="0,0,0,4">

          <Button Click="ApplyAll_Click" Background="Transparent" BorderThickness="0"
                  Width="58" Height="48" Cursor="Hand" FocusVisualStyle="{x:Null}"
                  ToolTip="Apply All — write git config to all repositories">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border x:Name="Bg" Background="Transparent">
                  <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Apply" FontSize="8" HorizontalAlignment="Center"
                               Margin="0,2,0,0" Foreground="{DynamicResource SecondaryText}"/>
                  </StackPanel>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBg}"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Button.Template>
          </Button>

          <Button Click="Theme_Click" Background="Transparent" BorderThickness="0"
                  Width="58" Height="48" Cursor="Hand" FocusVisualStyle="{x:Null}"
                  ToolTip="{Binding CurrentTheme, Converter={StaticResource ThemeName}}">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border x:Name="Bg" Background="Transparent">
                  <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock FontSize="16" HorizontalAlignment="Center">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Text" Value="🌙"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.CurrentTheme, ElementName=RootWindow}" Value="Light">
                              <Setter Property="Text" Value="☀"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="Theme" FontSize="8" HorizontalAlignment="Center"
                               Margin="0,2,0,0" Foreground="{DynamicResource SecondaryText}"/>
                  </StackPanel>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBg}"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Button.Template>
          </Button>

        </StackPanel>
      </Grid>
    </Border>

    <!-- Divider -->
    <Border Grid.Column="1" Background="{DynamicResource SeparatorBrush}"/>

    <!-- ══ CONTENT AREA ════════════════════════════════════════ -->
    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="28"/>
      </Grid.RowDefinitions>

      <Grid Grid.Row="0">
        <views:AccountsPanel x:Name="AccountsPage" Opacity="0">
          <views:AccountsPanel.Style>
            <Style TargetType="UserControl">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding ActivePage}" Value="0">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </views:AccountsPanel.Style>
        </views:AccountsPanel>

        <views:RepositoriesPanel x:Name="ReposPage" Opacity="0">
          <views:RepositoriesPanel.Style>
            <Style TargetType="UserControl">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding ActivePage}" Value="1">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </views:RepositoriesPanel.Style>
        </views:RepositoriesPanel>
      </Grid>

      <!-- Status bar -->
      <Border Grid.Row="1"
              Background="{DynamicResource StatusBarBg}"
              BorderBrush="{DynamicResource SeparatorBrush}"
              BorderThickness="0,1,0,0" Padding="14,0">
        <Grid>
          <TextBlock Text="{Binding StatusText}"
                     Foreground="{DynamicResource SecondaryText}"
                     FontSize="{StaticResource FontXs}"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                      VerticalAlignment="Center">
            <TextBlock Text="git: " Foreground="{DynamicResource SecondaryText}"
                       FontSize="{StaticResource FontXs}"/>
            <TextBlock Text="{Binding SystemGitIdentity}"
                       Foreground="{DynamicResource SecondaryText}"
                       FontSize="{StaticResource FontXs}"
                       FontFamily="{StaticResource MonoFont}"/>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
