<Application x:Class="GitCredMan.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
    StartupUri is NOT set — window is created manually in App.xaml.cs
    so DI and theme are wired up before the first pixel renders.

    pack://application:,,,/ URIs load from inside the compiled exe,
    not from the filesystem — required for single-file publish to work.
  -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Themes/SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
