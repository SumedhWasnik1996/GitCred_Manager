<UserControl x:Class="GitCredMan.App.Views.AccountsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GitCredMan.App.Converters"
             Background="{DynamicResource WindowBg}">

  <UserControl.Resources>
    <conv:BoolToVisibility   x:Key="BoolToVis"/>
    <conv:NullToVisibility   x:Key="NullToVis"/>
    <conv:BoolToAccentBrush  x:Key="BoolToAccent"/>
    <conv:BoolToStar         x:Key="BoolToStar"/>

    <!-- Animated list item: fade + slide in on load -->
    <Style x:Key="AnimatedListItem" TargetType="ListBoxItem"
           BasedOn="{StaticResource {x:Type ListBoxItem}}">
      <Style.Triggers>
        <EventTrigger RoutedEvent="Loaded">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity"
                               From="0" To="1" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
              </DoubleAnimation>
              <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                  From="0,10,0,0" To="0,0,0,0" Duration="0:0:0.22">
                <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction>
              </ThicknessAnimation>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
      </Style.Triggers>
    </Style>

    <!-- Avatar hover-scale via ControlTemplate -->
    <ControlTemplate x:Key="AvatarTemplate" TargetType="Button">
      <Border x:Name="AvatarBorder" Width="36" Height="36" CornerRadius="18"
              Background="{DynamicResource CardBg}" BorderThickness="2">
        <Border.RenderTransform>
          <ScaleTransform x:Name="AvatarScale" ScaleX="1" ScaleY="1" CenterX="18" CenterY="18"/>
        </Border.RenderTransform>
        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Border>
      <ControlTemplate.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Trigger.EnterActions>
            <BeginStoryboard>
              <Storyboard>
                <DoubleAnimation Storyboard.TargetName="AvatarScale" Storyboard.TargetProperty="ScaleX" To="1.12" Duration="0:0:0.15">
                  <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="AvatarScale" Storyboard.TargetProperty="ScaleY" To="1.12" Duration="0:0:0.15">
                  <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
              </Storyboard>
            </BeginStoryboard>
          </Trigger.EnterActions>
          <Trigger.ExitActions>
            <BeginStoryboard>
              <Storyboard>
                <DoubleAnimation Storyboard.TargetName="AvatarScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                <DoubleAnimation Storyboard.TargetName="AvatarScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
              </Storyboard>
            </BeginStoryboard>
          </Trigger.ExitActions>
        </Trigger>
      </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Star button click-pop via ControlTemplate -->
    <ControlTemplate x:Key="StarTemplate" TargetType="Button">
      <Border x:Name="StarBg" Background="Transparent" Width="36" Height="36"
              CornerRadius="6" Cursor="Hand">
        <Border.RenderTransform>
          <ScaleTransform x:Name="StarScale" ScaleX="1" ScaleY="1" CenterX="18" CenterY="18"/>
        </Border.RenderTransform>
        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Border>
      <ControlTemplate.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter TargetName="StarBg" Property="Background" Value="{DynamicResource HoverBg}"/>
        </Trigger>
        <EventTrigger RoutedEvent="Button.Click">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetName="StarScale" Storyboard.TargetProperty="ScaleX"
                               From="1" To="1.35" Duration="0:0:0.08" AutoReverse="True"/>
              <DoubleAnimation Storyboard.TargetName="StarScale" Storyboard.TargetProperty="ScaleY"
                               From="1" To="1.35" Duration="0:0:0.08" AutoReverse="True"/>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
      </ControlTemplate.Triggers>
    </ControlTemplate>
  </UserControl.Resources>

  <Grid Margin="20,16,20,14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>   <!-- toolbar: title + ALL buttons -->
      <RowDefinition Height="12"/>
      <RowDefinition Height="*"/>      <!-- account list -->
      <RowDefinition Height="Auto"/>   <!-- default footer -->
      <RowDefinition Height="Auto"/>   <!-- detected identities panel -->
    </Grid.RowDefinitions>

    <!-- ── Toolbar: title + Add + Edit + Delete + Detect ─── -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>  <!-- title -->
        <ColumnDefinition Width="*"/>     <!-- spacer -->
        <ColumnDefinition Width="Auto"/>  <!-- Add -->
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="Auto"/>  <!-- Edit -->
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="Auto"/>  <!-- Delete -->
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="Auto"/>  <!-- Detect (separated) -->
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Column="0"
                 Text="Accounts"
                 FontSize="{StaticResource FontXl}"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource PrimaryText}"
                 VerticalAlignment="Center"/>

      <Button Grid.Column="2"
              Content="＋  Add"
              Style="{StaticResource AccentButton}"
              Padding="12,7"
              Click="AddBtn_Click"/>

      <Button Grid.Column="4"
              Content="✏  Edit"
              Padding="10,7"
              IsEnabled="{Binding SelectedAccount, Converter={StaticResource NullToVis},
                          ConverterParameter=bool}"
              Click="EditBtn_Click"/>

      <Button Grid.Column="6"
              Content="🗑  Delete"
              Style="{StaticResource DangerButton}"
              Padding="10,7"
              IsEnabled="{Binding SelectedAccount, Converter={StaticResource NullToVis},
                          ConverterParameter=bool}"
              Click="DeleteBtn_Click"/>

      <!-- Separator line -->
      <Border Grid.Column="7" Width="1" Background="{DynamicResource SeparatorBrush}"
              Margin="0,6" VerticalAlignment="Stretch"/>

      <!-- Detect button — always visible in toolbar -->
      <Button Grid.Column="8"
              Padding="10,7"
              Click="DetectBtn_Click"
              ToolTip="Scan local git configs to find existing git identities">
        <Button.Style>
          <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Content" Value="🔎  Detect"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsDetecting}" Value="True">
                <Setter Property="Content">
                  <Setter.Value>
                    <StackPanel Orientation="Horizontal">
                      <Canvas Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Canvas.RenderTransform>
                          <RotateTransform CenterX="6.5" CenterY="6.5" Angle="{Binding SpinnerAngle}"/>
                        </Canvas.RenderTransform>
                        <Path Stroke="{DynamicResource PrimaryText}" StrokeThickness="1.8"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 6.5,1 A 5.5,5.5 0 1,1 1,6.5"/>
                      </Canvas>
                      <TextBlock Text="Scanning…" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Setter.Value>
                </Setter>
                <Setter Property="IsEnabled" Value="False"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Button.Style>
      </Button>
    </Grid>

    <!-- ── Account cards list ──────────────────────────────── -->
    <ListBox Grid.Row="2"
             ItemsSource="{Binding Accounts}"
             SelectedItem="{Binding SelectedAccount}"
             x:Name="AccountList"
             ItemContainerStyle="{StaticResource AnimatedListItem}"
             ScrollViewer.VerticalScrollBarVisibility="Auto">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Grid MinHeight="58">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="44"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>

            <!-- Avatar with hover-scale -->
            <Button Grid.Column="0"
                    Template="{StaticResource AvatarTemplate}"
                    BorderBrush="{Binding IsDefault, Converter={StaticResource BoolToAccent}}"
                    IsHitTestVisible="False"
                    VerticalAlignment="Center">
              <TextBlock Text="{Binding AvatarInitial}"
                         FontWeight="SemiBold" FontSize="14"
                         Foreground="{DynamicResource PrimaryText}"/>
            </Button>

            <!-- Name + summary -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,8,0">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryText}"/>
                <Border Background="{DynamicResource AccentBrush}"
                        CornerRadius="{StaticResource RadiusSm}"
                        Padding="5,1" Margin="7,0,0,0" VerticalAlignment="Center"
                        Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}">
                  <TextBlock Text="DEFAULT" FontSize="9" FontWeight="Bold" Foreground="White"/>
                </Border>
              </StackPanel>
              <TextBlock Text="{Binding DisplaySummary}"
                         Foreground="{DynamicResource SecondaryText}"
                         FontSize="{StaticResource FontXs}" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Token dot -->
            <Ellipse Grid.Column="2" Width="7" Height="7"
                     Fill="{Binding HasStoredToken, Converter={StaticResource BoolToAccent}}"
                     VerticalAlignment="Center" Margin="0,0,8,0"
                     ToolTip="{Binding HasStoredToken, StringFormat='Token stored: {0}'}"/>

            <!-- Star button -->
            <Button Grid.Column="3"
                    Content="{Binding IsDefault, Converter={StaticResource BoolToStar}}"
                    Foreground="{Binding IsDefault, Converter={StaticResource BoolToAccent}}"
                    Template="{StaticResource StarTemplate}"
                    FontSize="17" VerticalAlignment="Center"
                    ToolTip="Set as global default"
                    Tag="{Binding}" Click="StarBtn_Click"/>
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- ── Default account footer ──────────────────────────── -->
    <Border Grid.Row="3"
            Background="{DynamicResource CardBg}"
            BorderBrush="{DynamicResource SeparatorBrush}"
            BorderThickness="1" CornerRadius="{StaticResource RadiusLg}"
            Padding="14,8" Margin="0,10,0,0"
            Visibility="{Binding DefaultAccount, Converter={StaticResource NullToVis}}">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="🌐  Default: " Foreground="{DynamicResource SecondaryText}"
                   FontSize="{StaticResource FontXs}"/>
        <TextBlock Text="{Binding DefaultAccount.Name}" FontWeight="SemiBold"
                   Foreground="{DynamicResource AccentBrush}" FontSize="{StaticResource FontXs}"/>
        <TextBlock Text="  —  applied to all unassigned repositories."
                   Foreground="{DynamicResource SecondaryText}" FontSize="{StaticResource FontXs}"/>
      </StackPanel>
    </Border>

    <!-- ── Detected identities panel ──────────────────────── -->
    <Border Grid.Row="4"
            Background="{DynamicResource CardBg}"
            BorderBrush="{DynamicResource SeparatorBrush}"
            BorderThickness="1" CornerRadius="{StaticResource RadiusLg}"
            Margin="0,8,0,0"
            Visibility="{Binding ShowDetectPanel, Converter={StaticResource BoolToVis}}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Panel header -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0,0,0,1" Padding="14,9">
          <Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="Detected Identities" FontWeight="SemiBold"
                         FontSize="{StaticResource FontSm}"
                         Foreground="{DynamicResource PrimaryText}"/>
              <TextBlock Text="{Binding DetectStatus}"
                         Foreground="{DynamicResource SecondaryText}"
                         FontSize="{StaticResource FontXs}"
                         VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
            <Button HorizontalAlignment="Right" Content="✕"
                    Style="{StaticResource GhostButton}"
                    Padding="6,4" Click="CollapseDetect_Click"/>
          </Grid>
        </Border>

        <!-- Results list -->
        <ScrollViewer Grid.Row="1" MaxHeight="200" VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding DiscoveredIdentities}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border BorderBrush="{DynamicResource SeparatorBrush}"
                        BorderThickness="0,0,0,1" Padding="14,9">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="120"/>
                      <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSm}"
                                   Foreground="{DynamicResource PrimaryText}"/>
                        <Border Background="{DynamicResource AccentBrush}"
                                CornerRadius="{StaticResource RadiusSm}"
                                Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="Visibility" Value="Collapsed"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGlobal}" Value="True">
                                  <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                          <TextBlock Text="global" FontSize="9" FontWeight="Bold" Foreground="White"/>
                        </Border>
                      </StackPanel>
                      <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource SecondaryText}"
                                 FontSize="{StaticResource FontXs}" Margin="0,1,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="{Binding SourceLabel}"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="{StaticResource FontXs}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                    <Button Grid.Column="2" VerticalAlignment="Center"
                            Tag="{Binding}" Click="ImportIdentity_Click">
                      <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                          <Setter Property="Content" Value="↳ Import"/>
                          <Setter Property="Padding" Value="7,4"/>
                          <Setter Property="FontSize" Value="11"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding AlreadyImported}" Value="True">
                              <Setter Property="IsEnabled" Value="False"/>
                              <Setter Property="Content" Value="✓ Done"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Button.Style>
                    </Button>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

  </Grid>
</UserControl>
