<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ════════════════════════════════════════════════════════
       LIGHT THEME  —  Windows 11 / Fluent Design
       ════════════════════════════════════════════════════════ -->

  <Color x:Key="Bg"          >#F3F3F3</Color>
  <Color x:Key="Surface"     >#FFFFFF</Color>
  <Color x:Key="Surface2"    >#F9F9F9</Color>
  <Color x:Key="Surface3"    >#EBEBEB</Color>
  <Color x:Key="Border"      >#E0E0E0</Color>
  <Color x:Key="Accent"      >#0067C0</Color>
  <Color x:Key="AccentHover" >#1975C9</Color>
  <Color x:Key="AccentPress" >#005BA4</Color>
  <Color x:Key="Text"        >#1A1A1A</Color>
  <Color x:Key="TextMuted"   >#606060</Color>
  <Color x:Key="TextFaint"   >#A0A0A0</Color>
  <Color x:Key="Success"     >#107C10</Color>
  <Color x:Key="Danger"      >#C42B1C</Color>
  <Color x:Key="Warning"     >#9D5D00</Color>
  <Color x:Key="DangerBg"    >#FDE7E9</Color>
  <Color x:Key="SuccessBg"   >#E8F5E9</Color>

  <!-- Brushes -->
  <SolidColorBrush x:Key="BgBrush"          Color="{StaticResource Bg}"/>
  <SolidColorBrush x:Key="SurfaceBrush"     Color="{StaticResource Surface}"/>
  <SolidColorBrush x:Key="Surface2Brush"    Color="{StaticResource Surface2}"/>
  <SolidColorBrush x:Key="Surface3Brush"    Color="{StaticResource Surface3}"/>
  <SolidColorBrush x:Key="BorderBrush"      Color="{StaticResource Border}"/>
  <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}"/>
  <SolidColorBrush x:Key="AccentPressBrush" Color="{StaticResource AccentPress}"/>
  <SolidColorBrush x:Key="TextBrush"        Color="{StaticResource Text}"/>
  <SolidColorBrush x:Key="TextMutedBrush"   Color="{StaticResource TextMuted}"/>
  <SolidColorBrush x:Key="TextFaintBrush"   Color="{StaticResource TextFaint}"/>
  <SolidColorBrush x:Key="SuccessBrush"     Color="{StaticResource Success}"/>
  <SolidColorBrush x:Key="DangerBrush"      Color="{StaticResource Danger}"/>
  <SolidColorBrush x:Key="WarningBrush"     Color="{StaticResource Warning}"/>
  <SolidColorBrush x:Key="DangerBgBrush"    Color="{StaticResource DangerBg}"/>
  <SolidColorBrush x:Key="SuccessBgBrush"   Color="{StaticResource SuccessBg}"/>

  <!-- Semantic aliases -->
  <SolidColorBrush x:Key="WindowBg"         Color="{StaticResource Bg}"/>
  <SolidColorBrush x:Key="PanelBg"          Color="{StaticResource Surface}"/>
  <SolidColorBrush x:Key="CardBg"           Color="{StaticResource Surface2}"/>
  <SolidColorBrush x:Key="InputBg"          Color="{StaticResource Surface}"/>
  <SolidColorBrush x:Key="InputBorder"      Color="{StaticResource Border}"/>
  <SolidColorBrush x:Key="InputFocusBorder" Color="{StaticResource Accent}"/>
  <SolidColorBrush x:Key="PrimaryText"      Color="{StaticResource Text}"/>
  <SolidColorBrush x:Key="SecondaryText"    Color="{StaticResource TextMuted}"/>
  <SolidColorBrush x:Key="SeparatorBrush"   Color="{StaticResource Border}"/>
  <SolidColorBrush x:Key="HoverBg"          Color="{StaticResource Surface3}"/>
  <SolidColorBrush x:Key="SelectedBg"       Color="{StaticResource Surface3}"/>
  <SolidColorBrush x:Key="TabBarBg"         Color="{StaticResource Surface}"/>
  <SolidColorBrush x:Key="StatusBarBg"      Color="{StaticResource Surface}"/>
  <SolidColorBrush x:Key="ScrollBg"         Color="{StaticResource Surface3}"/>
  <SolidColorBrush x:Key="ScrollThumb"      Color="{StaticResource Border}"/>

  <sys:Boolean x:Key="IsDark" xmlns:sys="clr-namespace:System;assembly=mscorlib">False</sys:Boolean>

</ResourceDictionary>
