<Window x:Class="GitCredMan.App.Views.AccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GitCredMan.App.Converters"
        Title="Add Account"
        Width="460" Height="Auto"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Icon="/Resources/Icons/app.ico"
        Background="{DynamicResource PanelBg}">

  <Window.Resources>
    <conv:BoolToVisibility x:Key="BoolToVis"/>
    <conv:InverseBool      x:Key="InvBool"/>
  </Window.Resources>

  <StackPanel Margin="28,24,28,24">

    <!-- Title -->
    <TextBlock x:Name="TitleBlock"
               Text="Add Account"
               FontSize="{StaticResource FontXl}"
               FontWeight="SemiBold"
               Foreground="{DynamicResource PrimaryText}"
               Margin="0,0,0,20"/>

    <!-- Account name -->
    <Label Content="Account Label  (e.g. Work GitHub, Personal GitLab)"/>
    <TextBox x:Name="NameBox"
             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
             Margin="0,0,0,14"/>

    <!-- Username -->
    <Label Content="Git Username"/>
    <TextBox x:Name="UsernameBox"
             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
             Margin="0,0,0,14"/>

    <!-- Email -->
    <Label Content="Email Address"/>
    <TextBox x:Name="EmailBox"
             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
             Margin="0,0,0,14"/>

    <!-- Host -->
    <Label Content="Host  (e.g. github.com, gitlab.com, your-enterprise.com)"/>
    <TextBox x:Name="HostBox"
             Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
             Margin="0,0,0,14"/>

    <!-- Token -->
    <Label>
      <TextBlock>
        <Run Text="Personal Access Token"/>
        <Run Text="  ·  " Foreground="{DynamicResource SecondaryText}"/>
        <Run Text="{Binding TokenHint, Mode=OneWay}"
             Foreground="{DynamicResource SecondaryText}"
             FontStyle="Italic"/>
      </TextBlock>
    </Label>
    <Grid Margin="0,0,0,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="8"/>
        <ColumnDefinition Width="62"/>
      </Grid.ColumnDefinitions>

      <!-- Password box (shown by default) -->
      <PasswordBox x:Name="TokenPasswordBox" Grid.Column="0"
                   PasswordChanged="TokenPasswordBox_PasswordChanged"/>

      <!-- Plain text box (shown when "Show" is active) -->
      <TextBox x:Name="TokenPlainBox" Grid.Column="0"
               Visibility="Collapsed"
               FontFamily="{StaticResource MonoFont}"
               TextChanged="TokenPlainBox_TextChanged"/>

      <Button x:Name="ShowHideBtn"
              Grid.Column="2"
              Content="Show"
              Click="ShowHideBtn_Click"
              ToolTip="Toggle token visibility"/>
    </Grid>

    <!-- Security note -->
    <Border Background="{DynamicResource CardBg}"
            BorderBrush="{DynamicResource SeparatorBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}"
            Padding="12,9"
            Margin="0,0,0,20">
      <TextBlock FontSize="{StaticResource FontXs}"
                 Foreground="{DynamicResource SecondaryText}"
                 TextWrapping="Wrap">
        <Run Text="🔒"/>
        <Run Text=" Token is stored encrypted in Windows Credential Manager (DPAPI). It is never written to disk in plaintext."/>
      </TextBlock>
    </Border>

    <!-- Validation error -->
    <Border Background="{DynamicResource DangerBgBrush}"
            BorderBrush="{DynamicResource DangerBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}"
            Padding="12,8"
            Margin="0,0,0,14"
            x:Name="ErrorBanner"
            Visibility="Collapsed">
      <TextBlock x:Name="ErrorText"
                 Foreground="{DynamicResource DangerBrush}"
                 FontSize="{StaticResource FontSm}"
                 TextWrapping="Wrap"/>
    </Border>

    <!-- Buttons -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Cancel"
              Width="90"
              Margin="0,0,10,0"
              IsCancel="True"
              Click="CancelBtn_Click"/>
      <Button Content="Save Account"
              Style="{StaticResource AccentButton}"
              Width="130"
              IsDefault="True"
              Click="SaveBtn_Click"/>
    </StackPanel>

  </StackPanel>
</Window>
